  "keyFeatures": [
    "Parallel download connections (up to 32)",
    "Multiple mirror support with automatic failover",
    "Beautiful Terminal User Interface (TUI)",
    "Headless server mode with HTTP API",
    "Browser extension for Chrome, Firefox, and Edge",
    "Sequential download mode for streaming media",
    "Daemon architecture for centralized management",
    "Work stealing and slow worker optimization",
    "Remote TUI connection support",
    "Auto-resume capability"
  ],
  "publicApiSurface": [
    "surge - Launch interactive TUI",
    "surge server - Start headless server",
    "surge connect - Connect to remote server",
    "surge add - Queue downloads via CLI",
    "surge ls - List downloads",
    "surge pause - Pause download",
    "surge resume - Resume download",
    "surge rm - Remove download",
    "surge refresh - Update download URL",
